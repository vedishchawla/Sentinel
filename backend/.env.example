# Sentinel Backend Environment Variables
# Copy this to .env and fill in your values

# LLM Provider: groq (default/free), openai, anthropic, ollama
SENTINEL_LLM_PROVIDER=groq

# Groq (free, fast — get key from https://console.groq.com)
SENTINEL_GROQ_API_KEY=your_groq_api_key_here
SENTINEL_GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI (optional)
# SENTINEL_OPENAI_API_KEY=your_openai_key_here
# SENTINEL_OPENAI_MODEL=gpt-4o

# Anthropic (optional)
# SENTINEL_ANTHROPIC_API_KEY=your_anthropic_key_here
# SENTINEL_ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Ollama (optional, local)
# SENTINEL_OLLAMA_BASE_URL=http://localhost:11434
# SENTINEL_OLLAMA_MODEL=llama3.1

# GitHub (for PR creation — get token from https://github.com/settings/tokens)
# SENTINEL_GITHUB_TOKEN=your_github_pat_here

# Docker Sandbox
SENTINEL_SANDBOX_ENABLED=true
SENTINEL_SANDBOX_TIMEOUT=120

# Server
SENTINEL_HOST=0.0.0.0
SENTINEL_PORT=8000
